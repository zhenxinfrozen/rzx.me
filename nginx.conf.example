# RZX.ME Nginx配置示例
# 适用于生产环境部署

server {
    listen 80;
    server_name rzx.me www.rzx.me;
    root /var/www/rzx.me/public;
    index index.php index.html;
    
    # 启用gzip压缩
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    
    # 静态资源缓存
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|woff|woff2|ttf|eot|svg)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
    
    # 主应用路由
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    
    # Admin后台路由 - 关键配置
    location /admin/ {
        # 静态资源直接访问
        location ~* ^/admin/(assets|css|js|images)/(.*)$ {
            try_files $uri =404;
        }
        
        # Admin控制器路由: /admin/controller-name → /admin/controllers/controller-name.php
        location ~ ^/admin/([a-zA-Z0-9\-_]+)/?$ {
            try_files $uri /admin/controllers/$1.php;
        }
        
        # 其他admin请求
        try_files $uri $uri/ /admin/index.php;
    }
    
    # PHP处理
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;  # 根据PHP版本调整
        fastcgi_index index.php;
    }
    
    # 安全防护
    location ~ /\.ht {
        deny all;
    }
    
    location ~ /\.(git|svn) {
        deny all;
    }
    
    # 隐藏敏感文件
    location ~* \.(conf|log|md)$ {
        deny all;
    }
}

# HTTPS重定向 (可选)
server {
    listen 443 ssl http2;
    server_name rzx.me www.rzx.me;
    
    # SSL证书配置
    ssl_certificate /path/to/ssl/certificate.crt;
    ssl_certificate_key /path/to/ssl/private.key;
    
    # SSL安全配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    
    # 其余配置同HTTP版本...
    root /var/www/rzx.me/public;
    index index.php index.html;
    
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    
    location /admin/ {
        location ~* ^/admin/(assets|css|js|images)/(.*)$ {
            try_files $uri =404;
        }
        
        location ~ ^/admin/([a-zA-Z0-9\-_]+)/?$ {
            try_files $uri /admin/controllers/$1.php;
        }
        
        try_files $uri $uri/ /admin/index.php;
    }
    
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;
        fastcgi_index index.php;
    }
}