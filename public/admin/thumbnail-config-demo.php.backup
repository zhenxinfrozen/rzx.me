<?php
// public/admin/thumbnail-config-demo.php - 直接访问版本
require_once '../../app/bootstrap.php';
require_once '../../app/Services/ThumbnailService.php';
require_once '../../app/Config/ThumbnailConfig.php';

$pageTitle = "缩略图配置演示";
$currentPage = 'thumbnail-config-demo';

// 应用自定义配置
ThumbnailConfig::applyCustomConfigs();

// 处理表单提交
$testResults = [];
if ($_POST) {
    $action = $_POST['action'] ?? '';
    $imagePath = $_POST['image_path'] ?? '';
    $pageType = $_POST['page_type'] ?? 'gallery';
    
    if ($action === 'test_generate' && $imagePath) {
        // 测试生成缩略图
        $fullPath = __DIR__ . '/../../public/assets/images/' . $imagePath;
        $fullPath = str_replace(['\\', '//'], '/', $fullPath);
        if (file_exists($fullPath)) {
            $thumbnailPath = ThumbnailService::generateForPage($fullPath, $pageType);
            $testResults['generate'] = [
                'success' => $thumbnailPath !== false,
                'path' => $thumbnailPath ? str_replace(__DIR__ . '/../../public/', '', $thumbnailPath) : null,
                'config' => ThumbnailService::getAllPageConfigs()[$pageType] ?? []
            ];
        } else {
            $testResults['generate'] = [
                'success' => false,
                'path' => null,
                'config' => ThumbnailService::getAllPageConfigs()[$pageType] ?? [],
                'error' => '源图片文件不存在: ' . $fullPath
            ];
        }
    
    if ($action === 'test_custom') {
        // 测试自定义配置
        $customConfig = [
            'width' => (int)($_POST['width'] ?? 200),
            'height' => (int)($_POST['height'] ?? 200),
            'quality' => (int)($_POST['quality'] ?? 80),
            'format' => $_POST['format'] ?? 'jpg',
            'crop' => isset($_POST['crop']),
            'directory' => $_POST['directory'] ?? 'custom-thumbs',
            'suffix' => $_POST['suffix'] ?? '_custom'
        ];
        
        if ($imagePath) {
            $fullPath = __DIR__ . '/../../public/assets/images/' . $imagePath;
            $fullPath = str_replace(['\\', '//'], '/', $fullPath);
            // 详细的调试信息
            $debugInfo = [
                'image_path_input' => $imagePath,
                'full_path' => $fullPath,
                'file_exists' => file_exists($fullPath),
                'custom_config' => $customConfig
            ];
            if (file_exists($fullPath)) {
                try {
                    $thumbnailPath = ThumbnailService::generateForPage($fullPath, $pageType, $customConfig);
                    $testResults['custom'] = [
                        'success' => $thumbnailPath !== false,
                        'path' => $thumbnailPath ? str_replace(__DIR__ . '/../../public/', '', $thumbnailPath) : null,
                        'config' => $customConfig,
                        'debug' => $debugInfo,
                        'error' => $thumbnailPath ? null : 'ThumbnailService::generateForPage 返回 false'
                    ];
                } catch (Exception $e) {
                    $testResults['custom'] = [
                        'success' => false,
                        'path' => null,
                        'config' => $customConfig,
                        'debug' => $debugInfo,
                        'error' => '生成异常: ' . $e->getMessage()
                    ];
                }
            } else {
                $testResults['custom'] = [
                    'success' => false,
                    'path' => null,
                    'config' => $customConfig,
                    'debug' => $debugInfo,
                    'error' => '源文件不存在: ' . $fullPath
                ];
            }
        } else {
            $testResults['custom'] = [
                'success' => false,
                'path' => null,
                'config' => $customConfig,
                'error' => '未提供图片路径'
            ];
        }
    }
}

// 获取所有可用配置

$allConfigs = ThumbnailService::getAllPageConfigs();
$customConfigs = ThumbnailConfig::getCustomConfigs();
?>

