# Apache URL重写规则 - 生产环境路由配置
# 功能: 静态文件直接访问 + 动态请求重定向到 index.php
# 注意: 仅用于 Apache 服务器，开发环境使用 dev-server.php

RewriteEngine On

# 开发目录直接访问 (不经过路由)
RewriteRule ^dev/(.*)$ dev/$1 [L]

# 管理后台静态资源直接访问
RewriteRule ^admin/(assets|css|js|images)/(.*)$ admin/$1/$2 [L]

# 网站静态资源直接访问  
RewriteRule ^assets/(.*)$ assets/$1 [L]

# 其他请求走路由器
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]