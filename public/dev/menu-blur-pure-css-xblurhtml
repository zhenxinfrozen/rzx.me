<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hover to Unblur (SVG+JS) Demo</title>
  <style>
    /* 基本页面样式 */
    body {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
      background-color: #fff;
      font-family: sans-serif;
      color: #333;
    }

    h2 { margin-bottom: 12px; }

    .unblur-on-hover-container img {
      width: 350px;
      height: auto;
      display: block;
      /* 使用 SVG filter（JS 会修改该 filter 的 stdDeviation） */
      filter: url(#motion-blur-horizontal);
      /* 作为兼容性回退：支持直接的 CSS blur 过渡（部分浏览器更流畅） */
      /* 浏览器会取 URL filter 或 CSS blur 二者之一，具体取决于实现；JS 动画专注于 URL filter */
      transition: filter 0.45s ease-in-out;
    }

    .controls {
      margin-top: 18px;
      font-size: 14px;
      color: #666;
    }

    .note { margin-top: 8px; color: #999; font-size: 12px; }
  </style>
</head>
<body>

  <!-- SVG 放在页面中（可见或不可见都行），feGaussianBlur 用 id 以便 JS 操控 -->
  <svg width="0" height="0" style="position:absolute;">
    <defs>
      <filter id="motion-blur-horizontal" x="-50%" y="-50%" width="200%" height="200%">
        <!-- 初始 stdDeviation 为 32 0（水平大模糊），JS 会更新它 -->
        <feGaussianBlur id="gblur" in="SourceGraphic" stdDeviation="32 0" />
      </filter>
    </defs>
  </svg>

  <h2>Hover over the image to make it clear (JS animated SVG filter)</h2>

  <div class="unblur-on-hover-container">
    <!-- 请把 src 替换为你本地的图片文件名或 URL -->
    <img id="demoImg" src="menu-cion-blog-pictures.png" alt="Demo Image">
  </div>

  <div class="controls">Hover to animate the SVG feGaussianBlur from horizontal blur → clear</div>
  <div class="note">说明：如果浏览器无法平滑处理 URL filter，可改用 CSS blur()（见注释）。</div>

  <script>
    // 参数（可调整）
    const START_X = 32; // 初始水平 stdDeviation
    const START_Y = 0;  // 初始垂直 stdDeviation
    const DURATION = 300; // 动画持续时间 ms（悬停到清晰）

    const img = document.getElementById('demoImg');
    const gblur = document.getElementById('gblur');

    // 当前动画控制变量
    let rafId = null;
    let animStart = null;
    let animFrom = START_X;
    let animTo = 0;
    let animDirection = 'in'; // 'in' = 去清晰, 'out' = 恢复模糊

    function setStdDeviation(x, y) {
      // 把值写入到 feGaussianBlur 的属性中
      gblur.setAttribute('stdDeviation', x + ' ' + y);
    }

    // ease function（可替换为其他 easing）
    function easeInOutQuad(t) {
      return t < 0.5 ? 2*t*t : -1 + (4 - 2*t)*t;
    }

    function animateTimestamp(ts) {
      if (!animStart) animStart = ts;
      const elapsed = ts - animStart;
      let progress = Math.min(1, elapsed / DURATION);
      progress = easeInOutQuad(progress);

      const current = animFrom + (animTo - animFrom) * progress;
      setStdDeviation(current, START_Y);

      if (elapsed < DURATION) {
        rafId = requestAnimationFrame(animateTimestamp);
      } else {
        // 结束，将动画状态清理
        animStart = null;
        rafId = null;
      }
    }

    function startAnimation(from, to) {
      // 停掉之前的动画
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
      animFrom = from;
      animTo = to;
      animStart = null;
      rafId = requestAnimationFrame(animateTimestamp);
    }

    // 鼠标进入：从当前值（或 START_X）动画到 0
    img.addEventListener('mouseenter', () => {
      // 读取当前 value（尽量已知，否则用 START_X）
      const currentAttr = parseFloat(gblur.getAttribute('stdDeviation')) || START_X;
      startAnimation(currentAttr, 0);
    });

    // 鼠标离开：从当前值动画回 START_X
    img.addEventListener('mouseleave', () => {
      const currentAttr = parseFloat(gblur.getAttribute('stdDeviation')) || 0;
      startAnimation(currentAttr, START_X);
    });

    // 页面加载时确保初始值正确
    setStdDeviation(START_X, START_Y);

    // 可选：触屏支持（触摸开始清晰，触摸结束恢复）
    img.addEventListener('touchstart', (e) => { e.preventDefault(); img.dispatchEvent(new Event('mouseenter')); }, {passive:false});
    img.addEventListener('touchend', () => img.dispatchEvent(new Event('mouseleave')));

    /*
      兼容性/备用方案说明：
      - 某些浏览器不会对 URL filter 做平滑插值（或渲染性能差），这时可以把 CSS 的 filter: blur(...) 作为回退。
      - 若希望用 CSS blur 做平滑过渡，替换 img 的样式：
          filter: blur(16px);
          transition: filter 0.45s ease-in-out;
        然后在 :hover 时使用 filter: blur(0);
      - 本示例重点是展示如何通过 JS 修改 SVG filter 参数（stdDeviation）来实现方向模糊的平滑变换。
    */
  </script>

</body>
</html>