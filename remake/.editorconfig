# EditorConfig - 跨编辑器的编码和格式统一配置
# https://editorconfig.org

# 根配置文件
root = true

# 所有文件的默认规则
[*]
# 字符编码：UTF-8 无 BOM（PHP 必须无 BOM）
charset = utf-8
# 换行符：LF（Unix 风格，Git 友好）
end_of_line = lf
# 文件末尾插入新行
insert_final_newline = true
# 删除行尾空格
trim_trailing_whitespace = true
# 缩进风格：空格
indent_style = space
# 缩进大小：4 个空格
indent_size = 4

# PHP 文件特殊配置
[*.php]
charset = utf-8
indent_size = 4
# PHP 文件绝对不能有 BOM！
insert_final_newline = true

# Markdown 文件（保留行尾空格，因为可能用于换行）
[*.md]
charset = utf-8
trim_trailing_whitespace = false
indent_size = 2

# JSON 文件
[*.json]
charset = utf-8
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
charset = utf-8
indent_size = 2

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx}]
charset = utf-8
indent_size = 2

# HTML/CSS
[*.{html,css,scss,sass}]
charset = utf-8
indent_size = 2

# XML 文件
[*.xml]
charset = utf-8
indent_size = 2

# Shell 脚本
[*.{sh,bash}]
charset = utf-8
end_of_line = lf
indent_size = 2

# Batch 文件（Windows 批处理）
[*.{bat,cmd}]
charset = utf-8
end_of_line = crlf
indent_size = 4

# 配置文件
[.{env,gitignore,gitattributes}]
charset = utf-8
indent_size = 2
