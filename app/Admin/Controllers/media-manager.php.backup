// ==================== 辅助函数 ====================

/**
 * 查找分类的缩略图
 */
function findCategoryThumbnail(string $module, string $categoryDir, string $categoryName): ?string
{
    $thumbDir = $categoryDir . '/thumbs';
    
    // 优先查找 icon-01.* 文件
    if (is_dir($thumbDir)) {
        $icons = glob($thumbDir . '/icon-01.*');
        if (!empty($icons)) {
            return "/assets/images/{$module}/{$categoryName}/thumbs/" . basename($icons[0]);
        }
    }

    // 查找第一张图片
    $images = glob($categoryDir . '/*.{jpg,jpeg,png,gif,webp}', GLOB_BRACE);
    if (!empty($images)) {
        sort($images);
        $firstImage = basename($images[0]);
        
        // 检查是否有缩略图
        if (is_dir($thumbDir) && file_exists($thumbDir . '/' . $firstImage)) {
            return "/assets/images/{$module}/{$categoryName}/thumbs/{$firstImage}";
        }
        
        return "/assets/images/{$module}/{$categoryName}/{$firstImage}";
    }

    return null;
}

/**
 * 查找媒体文件的缩略图
 */
function findMediaThumbnail(string $module, string $categoryDir, string $categoryName, string $fileName): string
{
    $thumbDir = $categoryDir . '/thumbs';
    
    // 检查是否有对应的缩略图
    if (is_dir($thumbDir) && file_exists($thumbDir . '/' . $fileName)) {
        return "/assets/images/{$module}/{$categoryName}/thumbs/{$fileName}";
    }

    // 对于视频，查找同名的图片缩略图
    $baseName = pathinfo($fileName, PATHINFO_FILENAME);
    $thumbs = glob($thumbDir . '/' . $baseName . '.{jpg,jpeg,png}', GLOB_BRACE);
    if (!empty($thumbs)) {
        return "/assets/images/{$module}/{$categoryName}/thumbs/" . basename($thumbs[0]);
    }

    // 返回原文件
    return "/assets/images/{$module}/{$categoryName}/{$fileName}";
}

/**
 * 格式化显示名称
 */
function formatDisplayName(string $name): string
{
    // 移除数字前缀
    $name = preg_replace('/^\d+-/', '', $name);
    
    // 替换连字符和下划线为空格
    $name = str_replace(['-', '_'], ' ', $name);
    
    // 首字母大写
    return ucwords($name);
}

/**
 * 返回 JSON 响应
 */
function respondJson(array $payload, int $status = 200): void
{
    http_response_code($status);
    header('Content-Type: application/json; charset=utf-8');
    echo json_encode($payload, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit;
}
