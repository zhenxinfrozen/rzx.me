<?php
// app/Services/ThumbnailConfigManager.php
// 缩略图配置管理器 - 支持动态添加、保存、使用自定义配置

class ThumbnailConfigManager {
    
    private static $configFile = __DIR__ . '/../Data/thumbnail_configs.json';
    private static $builtinConfigs = [
        'gallery' => [
            'name' => 'Gallery页面',
            'width' => 300,
            'height' => 300,
            'quality' => 85,
            'format' => 'jpg',
            'crop' => false,
            'suffix' => '_gallery',
            'directory' => 'gallery-thumbs',
            'builtin' => true
        ],
        'single-works' => [
            'name' => 'Single-Works页面',
            'width' => 200,
            'height' => 200,
            'quality' => 80,
            'format' => 'jpg',
            'crop' => false,
            'suffix' => '_works',
            'directory' => 'works-thumbs',
            'builtin' => true
        ],
        'sketch' => [
            'name' => 'Sketch页面',
            'width' => 150,
            'height' => 150,
            'quality' => 75,
            'format' => 'jpg',
            'crop' => true,
            'suffix' => '_sketch',
            'directory' => 'sketch-thumbs',
            'builtin' => true
        ],
        'icon' => [
            'name' => '图标用途',
            'width' => 100,
            'height' => 100,
            'quality' => 80,
            'format' => 'png',
            'crop' => true,
            'suffix' => '_icon',
            'directory' => 'icons',
            'builtin' => true
        ]
    ];
    
    /**
     * 获取所有配置（内置 + 自定义）
     */
    public static function getAllConfigs() {
        $customConfigs = self::loadCustomConfigs();
        return array_merge(self::$builtinConfigs, $customConfigs);
    }
    
    /**
     * 获取指定配置
     */
    public static function getConfig($configId) {
        $allConfigs = self::getAllConfigs();
        return $allConfigs[$configId] ?? null;
    }
    
    /**
     * 添加自定义配置
     */
    public static function addCustomConfig($configId, $config) {
        // 验证配置
        $requiredFields = ['name', 'width', 'height', 'quality', 'format', 'suffix', 'directory'];
        foreach ($requiredFields as $field) {
            if (!isset($config[$field]) || empty($config[$field])) {
                throw new Exception("配置字段 '{$field}' 是必需的");
            }
        }
        
        // 检查ID是否已存在
        if (isset(self::$builtinConfigs[$configId])) {
            throw new Exception("配置ID '{$configId}' 与内置配置冲突");
        }
        
        // 加载现有自定义配置
        $customConfigs = self::loadCustomConfigs();
        
        // 添加新配置
        $config['builtin'] = false;
        $config['created_at'] = date('Y-m-d H:i:s');
        $customConfigs[$configId] = $config;
        
        // 保存
        return self::saveCustomConfigs($customConfigs);
    }
    
    /**
     * 更新自定义配置
     */
    public static function updateCustomConfig($configId, $config) {
        $customConfigs = self::loadCustomConfigs();
        
        if (!isset($customConfigs[$configId])) {
            throw new Exception("自定义配置 '{$configId}' 不存在");
        }
        
        // 保持创建时间，更新修改时间
        $config['builtin'] = false;
        $config['created_at'] = $customConfigs[$configId]['created_at'] ?? date('Y-m-d H:i:s');
        $config['updated_at'] = date('Y-m-d H:i:s');
        $customConfigs[$configId] = $config;
        
        return self::saveCustomConfigs($customConfigs);
    }
    
    /**
     * 删除自定义配置
     */
    public static function deleteCustomConfig($configId) {
        if (isset(self::$builtinConfigs[$configId])) {
            throw new Exception("不能删除内置配置");
        }
        
        $customConfigs = self::loadCustomConfigs();
        
        if (!isset($customConfigs[$configId])) {
            throw new Exception("自定义配置 '{$configId}' 不存在");
        }
        
        unset($customConfigs[$configId]);
        return self::saveCustomConfigs($customConfigs);
    }
    
    /**
     * 获取内置配置列表
     */
    public static function getBuiltinConfigs() {
        return self::$builtinConfigs;
    }
    
    /**
     * 获取自定义配置列表
     */
    public static function getCustomConfigs() {
        return self::loadCustomConfigs();
    }
    
    /**
     * 加载自定义配置
     */
    private static function loadCustomConfigs() {
        if (!file_exists(self::$configFile)) {
            return [];
        }
        
        $json = file_get_contents(self::$configFile);
        $configs = json_decode($json, true);
        
        return is_array($configs) ? $configs : [];
    }
    
    /**
     * 保存自定义配置
     */
    private static function saveCustomConfigs($configs) {
        // 确保目录存在
        $dir = dirname(self::$configFile);
        if (!is_dir($dir)) {
            mkdir($dir, 0755, true);
        }
        
        $json = json_encode($configs, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
        return file_put_contents(self::$configFile, $json) !== false;
    }
    
    /**
     * 验证配置ID格式
     */
    public static function validateConfigId($configId) {
        // 只允许字母、数字、下划线、连字符
        if (!preg_match('/^[a-zA-Z0-9_-]+$/', $configId)) {
            throw new Exception("配置ID只能包含字母、数字、下划线和连字符");
        }
        
        // 长度限制
        if (strlen($configId) < 2 || strlen($configId) > 50) {
            throw new Exception("配置ID长度必须在2-50个字符之间");
        }
        
        return true;
    }
    
    /**
     * 生成配置ID建议
     */
    public static function suggestConfigId($name) {
        // 转换为小写，替换空格和特殊字符为连字符
        $id = strtolower($name);
        $id = preg_replace('/[^a-zA-Z0-9]+/', '-', $id);
        $id = trim($id, '-');
        
        // 如果ID已存在，添加数字后缀
        $originalId = $id;
        $counter = 1;
        while (self::getConfig($id) !== null) {
            $id = $originalId . '-' . $counter;
            $counter++;
        }
        
        return $id;
    }
    
    /**
     * 导出配置
     */
    public static function exportConfigs($includeBuiltin = false) {
        $configs = $includeBuiltin ? self::getAllConfigs() : self::getCustomConfigs();
        return [
            'exported_at' => date('Y-m-d H:i:s'),
            'total_count' => count($configs),
            'configs' => $configs
        ];
    }
    
    /**
     * 导入配置
     */
    public static function importConfigs($data, $overwrite = false) {
        if (!isset($data['configs']) || !is_array($data['configs'])) {
            throw new Exception("无效的导入数据格式");
        }
        
        $imported = 0;
        $skipped = 0;
        $errors = [];
        
        foreach ($data['configs'] as $configId => $config) {
            try {
                // 跳过内置配置
                if (isset($config['builtin']) && $config['builtin']) {
                    $skipped++;
                    continue;
                }
                
                // 检查是否已存在
                if (self::getConfig($configId) !== null && !$overwrite) {
                    $skipped++;
                    continue;
                }
                
                // 添加或更新配置
                if (self::getConfig($configId) !== null) {
                    self::updateCustomConfig($configId, $config);
                } else {
                    self::addCustomConfig($configId, $config);
                }
                
                $imported++;
                
            } catch (Exception $e) {
                $errors[] = "配置 '{$configId}': " . $e->getMessage();
            }
        }
        
        return [
            'imported' => $imported,
            'skipped' => $skipped,
            'errors' => $errors
        ];
    }
}