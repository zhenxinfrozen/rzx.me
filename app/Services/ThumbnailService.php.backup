    /**
     * 为指定页面生成缩略图
     * 
     * @param string $sourcePath 源图片路径
     * @param string $pageType 页面类型（gallery/single-works/sketch/icon/large）
     * @param array $customConfig 自定义配置（可选）
     * @return string|false 缩略图路径或false
     */
    public static function generateForPage($sourcePath, $pageType = 'gallery', $customConfig = []) {
        // 获取页面配置
        $config = self::getPageConfig($pageType, $customConfig);
        
        // 生成缩略图路径
        $thumbnailPath = self::generateThumbnailPath($sourcePath, $config);
        
        // 检查缩略图是否需要更新
        if (file_exists($thumbnailPath) && filemtime($thumbnailPath) >= filemtime($sourcePath)) {
            return $thumbnailPath;
        }
        
        // 检查源文件是否存在
        if (!file_exists($sourcePath)) {
            error_log("ThumbnailService: Source file not found: {$sourcePath}");
            return false;
        }
        
        // 检查目标目录是否可写
        $thumbnailDir = dirname($thumbnailPath);
        if (!is_dir($thumbnailDir)) {
            if (!mkdir($thumbnailDir, 0755, true)) {
                error_log("ThumbnailService: Cannot create thumbnail directory: {$thumbnailDir}");
                return false;
            }
        }
        
        if (!is_writable($thumbnailDir)) {
            error_log("ThumbnailService: Thumbnail directory not writable: {$thumbnailDir}");
            return false;
        }
        
        // 记录生成请求
        error_log("ThumbnailService: Generating thumbnail from {$sourcePath} to {$thumbnailPath} with config: " . json_encode($config));
        
        // 生成缩略图
        $result = ThumbnailGenerator::generate($sourcePath, $thumbnailPath, $config);
        
        // 记录结果
        if ($result === false) {
            error_log("ThumbnailService: ThumbnailGenerator::generate returned false");
        } else {
            error_log("ThumbnailService: Successfully generated thumbnail: {$result}");
        }
        
        return $result;
    }
    
    /**
     * 批量生成指定目录的缩略图
     * 
     * @param string $directoryPath 图片目录路径
     * @param string $pageType 页面类型
     * @param array $customConfig 自定义配置
     * @return array 生成结果
     */
    public static function generateBatchForPage($directoryPath, $pageType = 'gallery', $customConfig = []) {
        $config = self::getPageConfig($pageType, $customConfig);
        $results = [];
        
        // 扫描图片文件
        $supportedTypes = ['jpg', 'jpeg', 'png', 'gif', 'webp'];
        $files = scandir($directoryPath);
        
        foreach ($files as $file) {
            if ($file === '.' || $file === '..' || is_dir($directoryPath . '/' . $file)) {
                continue;
            }
            
            $extension = strtolower(pathinfo($file, PATHINFO_EXTENSION));
            if (!in_array($extension, $supportedTypes)) {
                continue;
            }
            
            $sourcePath = $directoryPath . '/' . $file;
            $thumbnailPath = self::generateForPage($sourcePath, $pageType, $customConfig);
            
            $results[] = [
                'source' => $file,
                'success' => $thumbnailPath !== false,
                'thumbnail' => $thumbnailPath ? basename($thumbnailPath) : null,
                'config' => $config
            ];
        }
        
        return $results;
    }
    
    /**
     * 获取缩略图路径（如果存在）
     * 
     * @param string $sourcePath 源图片路径
     * @param string $pageType 页面类型
     * @param array $customConfig 自定义配置
     * @return string|false 缩略图路径或false
     */
    public static function getThumbnailPath($sourcePath, $pageType = 'gallery', $customConfig = []) {
        $config = self::getPageConfig($pageType, $customConfig);
        $thumbnailPath = self::generateThumbnailPath($sourcePath, $config);
        
        return file_exists($thumbnailPath) ? $thumbnailPath : false;
    }
    
    /**
     * 获取页面配置
     * 
     * @param string $pageType 页面类型
     * @param array $customConfig 自定义配置
     * @return array 合并后的配置
     */
    private static function getPageConfig($pageType, $customConfig = []) {
        // 尝试从配置管理器获取配置
        $config = ThumbnailConfigManager::getConfig($pageType);
        
        if ($config) {
            // 移除管理字段，只保留缩略图相关配置
            unset($config['name'], $config['builtin'], $config['created_at'], $config['updated_at']);
            $baseConfig = $config;
        } else {
            // 回退到内置配置
            $baseConfig = isset(self::$pageConfigs[$pageType]) 
                ? self::$pageConfigs[$pageType] 
                : self::$pageConfigs['gallery'];  // 默认使用gallery配置
        }
        
        return array_merge($baseConfig, $customConfig);
    }
    
    /**
     * 生成缩略图路径
     * 
     * @param string $sourcePath 源图片路径
     * @param array $config 配置选项
     * @return string 缩略图路径
     */
    private static function generateThumbnailPath($sourcePath, $config) {
        $pathInfo = pathinfo($sourcePath);
        $directory = $pathInfo['dirname'];
        $filename = $pathInfo['filename'];
        $extension = strtolower($config['format']);
        
        // 创建缩略图目录
        $thumbsDir = $directory . '/' . $config['directory'];
        if (!is_dir($thumbsDir)) {
            mkdir($thumbsDir, 0755, true);
        }
        
        return $thumbsDir . '/' . $filename . $config['suffix'] . '.' . $extension;
    }
    
    /**
     * 添加或更新页面配置
     * 
     * @param string $pageType 页面类型
     * @param array $config 配置选项
     */
    public static function setPageConfig($pageType, $config) {
        self::$pageConfigs[$pageType] = array_merge(
            self::$pageConfigs['gallery'], // 基础配置
            $config
        );
    }
    
    /**
     * 获取所有页面配置
     * 
     * @return array 所有配置
     */
    public static function getAllPageConfigs() {
        return ThumbnailConfigManager::getAllConfigs();
    }
    
    /**
     * 清理指定目录的旧缩略图
     * 
     * @param string $directoryPath 图片目录路径
     * @param string $pageType 页面类型
     * @return int 删除的文件数量
     */
    public static function cleanOldThumbnails($directoryPath, $pageType = 'gallery') {
        $config = self::getPageConfig($pageType);
        $thumbsDir = $directoryPath . '/' . $config['directory'];
        
        if (!is_dir($thumbsDir)) {
            return 0;
        }
        
        // 获取源图片列表
        $supportedTypes = ['jpg', 'jpeg', 'png', 'gif', 'webp'];
        $sourceFiles = [];
        $files = scandir($directoryPath);
        
        foreach ($files as $file) {
            if ($file === '.' || $file === '..' || is_dir($directoryPath . '/' . $file)) {
                continue;
            }
            
            $extension = strtolower(pathinfo($file, PATHINFO_EXTENSION));
            if (in_array($extension, $supportedTypes)) {
                $sourceFiles[] = pathinfo($file, PATHINFO_FILENAME);
            }
        }
        
        // 检查并删除孤立的缩略图
        $deleted = 0;
        $thumbFiles = scandir($thumbsDir);
        
        foreach ($thumbFiles as $thumbFile) {
            if ($thumbFile === '.' || $thumbFile === '..') {
                continue;
            }
            
            $thumbName = pathinfo($thumbFile, PATHINFO_FILENAME);
            $originalName = str_replace($config['suffix'], '', $thumbName);
            
            if (!in_array($originalName, $sourceFiles)) {
                unlink($thumbsDir . '/' . $thumbFile);
                $deleted++;
            }
        }
        
        return $deleted;
    }
}